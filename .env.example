# Скопируйте в .env (локально) или задайте в Render → Environment

# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Ключ OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Строка подключения к PostgreSQL (Render даёт её автоматически через render.yaml)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Только для локального запуска через long polling:
RUN_MODE=polling

# На Render задаётся автоматически (можно не трогать):
# WEBHOOK_URL=https://your-bot.onrender.com
# PORT=10000

# Дефолтные настройки нового пользователя
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_DAILY_HOUR=21
DEFAULT_WEEKLY_DOW=6

# --- Монетизация (Telegram Stars) ---
MONETIZATION_ENABLED=0          # дефолт; реально управляется из админки (settings)
FREE_DAILY_AI=3                 # бесплатных анализов в день (в бесплатный период)
FREE_PERIOD_DAYS=30             # длина бесплатного периода с регистрации, дней
SUBSCRIPTION_PRICE_STARS=150    # цена Premium в звёздах (автопродление, 30 дней)
SUBSCRIPTION_DAYS=30            # длительность подписки
TRIAL_DAYS=3                    # дней безлимита новым пользователям (0 = выкл)
CREDIT_PACKS=50:70,200:220      # пакеты разовых анализов «кредитов:звёзд»
OPENAI_MODEL_FREE=gpt-4o-mini   # дешёвая модель для бесплатного тира
BYOK_ENCRYPTION_KEY=            # Fernet-ключ (Fernet.generate_key()); пусто = BYOK выкл
SUPPORT_CONTACT=@your_support   # контакт для /paysupport и /terms
ADMIN_IDS=123456789             # твой Telegram user_id для /addpromo, /refund, /stats

# --- Тестовая среда (sandbox) для оплаты звёздами ---
# 1 = слать запросы в тестовую среду Telegram (бесплатные звёзды).
# Включай ТОЛЬКО при локальном тесте с тестовым ботом, в проде оставь 0.
TELEGRAM_TEST_ENV=0

# --- Веб-админка (папка admin/, отдельный сервис) ---
# Базовые логин/пароль (ПОМЕНЯЙ пароль!). Логин можно сделать своим email.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=Zhiromer-Admin-2026
SECRET_KEY=поставь-случайную-строку
STAR_USD=0.013                 # курс звезды для оценки выручки в аналитике
